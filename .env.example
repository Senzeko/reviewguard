# ─────────────────────────────────────────────────────────────────────────────
# ReviewGuard AI — environment variables
# Copy this file to .env and fill in real values before running the app.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL connection string (used by Drizzle ORM and drizzle-kit)
DATABASE_URL=postgresql://user:password@localhost:5432/reviewguard

# Redis connection string (used by ioredis queue client)
REDIS_URL=redis://localhost:6379

# AES-256-GCM encryption key for POS API credentials stored in transactions_vault.
# Must be exactly 64 hex characters (32 bytes).
# Generate a fresh key with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# Anthropic API key — used by Session 3 for LLM-based line-item extraction
# in the ForensicMatchEngine.
ANTHROPIC_API_KEY=

# Google Places API key — used by Session 2 for webhook verification
# and Google Review data fetching.
GOOGLE_PLACES_API_KEY=

# Square OAuth application credentials — used by Session 2 for POS OAuth flow.
SQUARE_APPLICATION_ID=
SQUARE_APPLICATION_SECRET=

# Clover OAuth application credentials — used by Session 2 for POS OAuth flow.
CLOVER_APP_ID=
CLOVER_APP_SECRET=

# Node environment. Controls seed guard, logging verbosity, etc.
# Values: development | production | test
NODE_ENV=development

# Port for the HTTP API server — used by Session 2 when standing up Express routes.
PORT=3000

# Absolute path to evidence vault directory
# In production, replace with a mounted volume or S3 bucket path
EVIDENCE_VAULT_PATH=./evidence_vault

# ── Email Notifications (optional — logs to console if not set) ───────────────
# SMTP configuration for transactional emails
# Leave blank in development to log emails to console instead
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=ReviewGuard AI <noreply@reviewguard.ai>

# Public-facing app URL (used in email links)
APP_URL=http://localhost:5173
