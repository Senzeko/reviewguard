{
  "name": "reviewguard",
  "version": "0.1.0",
  "description": "PodSignal — growth and sponsorship OS for podcasts",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:all": "concurrently -k -n api,web -c blue,green \"npm run dev\" \"npm run client:dev\"",
    "stripe:listen": "stripe listen --forward-to localhost:3000/api/billing/webhook",
    "build": "npm run build:server && npm run client:build",
    "build:server": "tsc",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:apply-0009": "tsx scripts/apply-migration-0009.ts",
    "db:apply-0010": "tsx scripts/apply-migration-0010.ts",
    "db:apply-0011": "tsx scripts/apply-migration-0011.ts",
    "db:apply-0012": "tsx scripts/apply-migration-0012.ts",
    "db:apply-0013": "tsx scripts/apply-migration-0013.ts",
    "db:apply-0014": "tsx scripts/apply-migration-0014.ts",
    "db:apply-0015": "tsx scripts/apply-migration-0015.ts",
    "db:apply-0016": "tsx scripts/apply-migration-0016.ts",
    "db:apply-0017": "tsx scripts/apply-migration-0017.ts",
    "db:apply-0018": "tsx scripts/apply-migration-0018.ts",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/db/seed.ts",
    "db:purge-names": "tsx -e \"import('./src/db/index.js').then(({db})=>db.execute('SELECT purge_expired_name_plain_temp()').then(r=>{ console.log('Purged:', r); process.exit(0); }))\"",
    "queue:flush": "tsx -e \"import('./src/queue/client.js').then(({redis})=>redis.flushdb().then(()=>{ console.log('Queue flushed'); process.exit(0); }))\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:reliability": "playwright test -c playwright.reliability.config.ts",
    "release:check": "npm run build && npm test",
    "test:e2e:ui": "playwright test --ui",
    "test:admt": "playwright test tests/admt/",
    "test:all": "npm run test:unit && npm run test:e2e",
    "test:fpr": "tsx tests/fpr/runner.ts",
    "test:load": "tsx tests/load/engine.ts",
    "test:load:podsignal": "tsx tests/load/podsignal.ts",
    "test:report": "tsx tests/report.ts",
    "preflight": "tsx tests/preflight.ts",
    "client:install": "cd client && npm install",
    "client:build": "cd client && npm run build",
    "client:dev": "cd client && npm run dev",
    "start": "node dist/index.js",
    "setup": "npm install && npm run client:install && npm run db:migrate",
    "email:test": "tsx scripts/send-test-email.ts",
    "railway:login": "npx --yes @railway/cli@latest login",
    "railway:link": "npx --yes @railway/cli@latest link",
    "railway:setup-env": "bash scripts/railway-env-setup.sh"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/formbody": "^8.0.2",
    "@fastify/multipart": "^9.4.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^9.0.0",
    "axios": "^1.13.6",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.36.4",
    "fastify": "^5.8.4",
    "ioredis": "^5.4.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.4",
    "pdf-lib": "^1.17.1",
    "pg": "^8.13.1",
    "stripe": "^21.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/autocannon": "^7.12.7",
    "@types/node": "^22.10.2",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.11.10",
    "autocannon": "^8.0.0",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.28.1",
    "playwright": "^1.58.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.1"
  }
}
